{
    "name": "ophelios/leaf",
    "description": "Project template for Zephyrus Leaf static sites. Docs, blogs, landing pages.",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "David Tucker",
            "email": "david.tucker@ophelios.com"
        }
    ],
    "repositories": [
        {
            "type": "path",
            "url": "../zephyrus2"
        },
        {
            "type": "path",
            "url": "../zephyrus-leaf-core"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^8.4",
        "dadajuice/zephyrus-leaf": "@dev",
        "ext-intl": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "symfony/var-dumper": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\Controllers\\": "app/Controllers",
            "App\\Models\\": "app/Models"
        }
    },
    "scripts": {
        "dev": "php -S localhost:8080 -t public bin/router.php",
        "build": "php bin/build.php"
    },
    "config": {
        "sort-packages": true,
        "process-timeout": 0
    }
}
